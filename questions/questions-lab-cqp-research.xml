  <question type="coderunner">
    <name>
      <text>Task C — Grade Classifier</text>
    </name>
    <questiontext format="html">
      <text><![CDATA[<p>Write a function <code>classify_grade(score)</code> that takes a numeric score between 0 and 100 and returns the corresponding letter grade as a string.</p>
<table>
  <thead><tr><th>Score</th><th>Grade</th></tr></thead>
  <tbody>
    <tr><td>90 and above</td><td>A</td></tr>
    <tr><td>80 to 89</td><td>B</td></tr>
    <tr><td>70 to 79</td><td>C</td></tr>
    <tr><td>60 to 69</td><td>D</td></tr>
    <tr><td>Below 60</td><td>F</td></tr>
  </tbody>
</table>]]></text>
    </questiontext>
