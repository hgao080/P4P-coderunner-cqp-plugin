    <answer>def classify_grade(score):
    """Return the letter grade for a numeric score."""
    A_THRESHOLD = 90
    B_THRESHOLD = 80
    C_THRESHOLD = 70
    D_THRESHOLD = 60
    if score >= A_THRESHOLD:
        return 'A'
    if score >= B_THRESHOLD:
        return 'B'
    if score >= C_THRESHOLD:
        return 'C'
    if score >= D_THRESHOLD:
        return 'D'
    return 'F'</answer>
