{{!
    @template local_coderunner_cqp_linter/lint_panel

    Renders the CQP-based code quality results panel below CodeRunner feedback.

    Messages are grouped by CQP principle rather than pylint severity,
    showing the principle name, description, and guideline alongside violations.

    Classes required for JS: none (server-rendered, positioned by lint_injector.js)

    Data attributes:
    - data-region="pylint-results"

    Context variables required:
    - panelid (string): Unique ID for the panel element
    - has_error (bool): Whether pylint execution failed
    - error_message (string): Error message if has_error is true
    - has_messages (bool): Whether there are any lint messages
    - cqp_groups (array): Groups of messages by CQP principle
    - total_issues (int): Total number of issues found
    - no_issues_message (string): Message when no issues found

    Example context (json):
    {
        "panelid": "pylint-panel-1",
        "has_error": false,
        "has_messages": true,
        "cqp_groups": [
            {
                "cqp_number": 2,
                "cqp_name": "Explanatory Language",
                "cqp_short": "The rationale, intent and meaning of code is explicit.",
                "cqp_guideline": "Names should be descriptive and comments should clarify intent.",
                "count": 1,
                "messages": [
                    {
                        "line": 5,
                        "messageid": "C0114",
                        "symbol": "missing-module-docstring",
                        "message": "Missing module docstring",
                        "severityclass": "pylint-convention",
                        "cqp_number": 2,
                        "cqp_name": "Explanatory Language",
                        "cqp_guideline": "Names should be descriptive."
                    }
                ]
            }
        ],
        "total_issues": 1
    }
}}
<div id="{{panelid}}" class="coderunner-pylint-panel" data-region="pylint-results" style="display:none;">
    <details open>
        <summary class="pylint-header">
            <span class="pylint-title">
                {{#str}}lintresults, local_coderunner_cqp_linter{{/str}}
            </span>
            {{#total_issues}}
                <span class="badge badge-secondary pylint-count">
                    {{total_issues}} issue{{#total_issues}}{{/total_issues}}
                </span>
            {{/total_issues}}
        </summary>

        <div class="pylint-body">
            {{#has_error}}
                <div class="alert alert-warning pylint-error-msg">
                    {{{error_message}}}
                </div>
            {{/has_error}}

            {{^has_error}}
                {{#has_messages}}
                    <div class="cqp-principle-summary">
                        {{#cqp_groups}}
                        <span class="cqp-principle-badge cqp-principle-{{cqp_number}}"
                              data-cqp-number="{{cqp_number}}"
                              title="{{cqp_short}}">
                            CQP {{cqp_number}}: {{cqp_name}}
                            <span class="cqp-badge-count">({{count}})</span>
                        </span>
                        {{/cqp_groups}}
                    </div>
                    {{#cqp_groups}}
                        <div class="cqp-group" data-cqp-number="{{cqp_number}}">
                            <div class="cqp-group-header cqp-principle-{{cqp_number}}-header">
                                <strong>CQP {{cqp_number}}: {{cqp_name}}</strong>
                                <span class="cqp-group-count">({{count}})</span>
                            </div>
                            <div class="cqp-group-guideline">
                                {{cqp_guideline}}
                            </div>
                            <table class="table table-sm table-striped pylint-messages">
                                <thead class="sr-only">
                                    <tr>
                                        <th>{{#str}}line, local_coderunner_cqp_linter{{/str}}</th>
                                        <th>{{#str}}messagecol, local_coderunner_cqp_linter{{/str}}</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {{#messages}}
                                        {{> local_coderunner_cqp_linter/lint_message }}
                                    {{/messages}}
                                </tbody>
                            </table>
                        </div>
                    {{/cqp_groups}}
                {{/has_messages}}

                {{^has_messages}}
                    <div class="pylint-clean">
                        {{no_issues_message}}
                    </div>
                {{/has_messages}}
            {{/has_error}}
        </div>
    </details>
</div>
